# Copy this file to .env.dev and edit the copied file for your local installation.
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 testserver
CSRF_TRUSTED_ORIGINS=http://localhost http://127.0.0.1
DEBUG=True
CATHI_ENV=development
SECRET_KEY=CHANGE-ME-INVALID-DEV-SECRET-KEY
SECRET_KEY_FILE=

SQL_ENGINE=django.db.backends.postgresql_psycopg2
SQL_DATABASE=Cpostgres
SQL_USER=postgres
SQL_PASSWORD=postgres
SQL_PASSWORD_FILE=
SQL_HOST=postgres
SQL_PORT=5432

TZ=Europe/Berlin
DEFAULT_AUTO_FIELD=django.db.models.AutoField
STATIC_RESULT_IMAGES=static/images/result_images/
BLAST_PROJECT_DIR=media/blast_projects/
REMOTE_BLAST_PROJECT_DIR=media/blast_projects/remote_projects/
ONE_WAY_BLAST_PROJECT_DIR=media/one_way_blast/
BLAST_DATABASE_DIR=media/databases/
CDD_DIR=media/databases/CDD/
ESEARCH_OUTPUT=media/esearch_output/

# Required reference-data URLs. Review and change these in .env.dev if your installation needs other mirrors.
CDD_DATABASE_URL=https://ftp.ncbi.nlm.nih.gov/pub/mmdb/cdd/little_endian/Cdd_LE.tar.gz
TAXDB_URL=https://ftp.ncbi.nlm.nih.gov/blast/db/taxdb.tar.gz
REFSEQ_ASSEMBLY_FILE=media/databases/refseq_summary_file/
REFSEQ_URL=https://ftp.ncbi.nlm.nih.gov/genomes/refseq/assembly_summary_refseq.txt
GENBANK_ASSEMBLY_FILE=media/databases/refseq_summary_file/
GENBANK_URL=https://ftp.ncbi.nlm.nih.gov/genomes/genbank/assembly_summary_genbank.txt
TAXONOMIC_NODES=media/taxonomic_node_files/

PROTECTED_MEDIA_ROOT=media
PROTECTED_MEDIA_USE_X_ACCEL=False
PROTECTED_MEDIA_INTERNAL_URL=/_protected_media/

FLOWER_BASIC_AUTH=CHANGE-ME-INVALID-FLOWER-USER:CHANGE-ME-INVALID-FLOWER-PASSWORD
JUPYTER_TOKEN=CHANGE-ME-INVALID-JUPYTER-TOKEN

CELERY_INTERACTIVE_QUEUE=interactive
CELERY_WORKFLOW_QUEUE=long_bio
CELERY_MAINTENANCE_QUEUE=maintenance
CELERY_INTERACTIVE_WORKER_CONCURRENCY=2
CELERY_WORKFLOW_WORKER_CONCURRENCY=1
CELERY_MAINTENANCE_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=True
CELERY_TASK_REJECT_ON_WORKER_LOST=True
RABBITMQ_CONSUMER_TIMEOUT_MS=346000000

CATHI_WORKFLOW_JOB_CORES=1
CATHI_MAX_BLAST_THREADS=1
CATHI_MAX_NUM_ALIGNMENTS=10000
CATHI_MAX_TARGET_SEQS=10000
CATHI_MAX_HSPS=500
CATHI_MAX_RBHS_FOR_PHYLO=500
CATHI_MAX_ENTREZ_RECORDS=10000
CATHI_MAX_UPLOAD_BYTES=104857600
CATHI_MAX_ACTIVE_WORKFLOWS_PER_USER=1

WEB_CPUS=2.0
WEB_MEM_LIMIT=16g
WEB_PIDS_LIMIT=512
CELERY_WORKFLOW_CPUS=1.0
CELERY_WORKFLOW_MEM_LIMIT=4g
CELERY_WORKFLOW_PIDS_LIMIT=256
CELERY_INTERACTIVE_CPUS=1.0
CELERY_INTERACTIVE_MEM_LIMIT=2g
CELERY_INTERACTIVE_PIDS_LIMIT=128
CELERY_MAINTENANCE_CPUS=1.0
CELERY_MAINTENANCE_MEM_LIMIT=2g
CELERY_MAINTENANCE_PIDS_LIMIT=128
